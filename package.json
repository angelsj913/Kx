{
  "name": "zeff-ai",
  "version": "1.0.0",
  "description": "ZEFF AI Workspace (Web, Desktop, Android)",
  "author": "ZEFF AI",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "prisma generate && node scripts/db-push-retry.mjs && next build",
    "db:push": "node scripts/db-push-retry.mjs",
    "start": "next start",
    "lint": "eslint",
    "rag:index:zeff": "npx tsx scripts/index-zeff-rag.mjs",
    "eval:ai": "npx tsx scripts/eval-ai.mts",
    "eval:ai:live": "npx tsx scripts/eval-ai.mts --live",
    "feedback:aggregate": "node scripts/aggregate-feedback.mjs",
    "rag:prepare-qa-source": "node scripts/prepare-rag-qa-source.mjs",
    "electron": "electron .",
    "electron:dev": "concurrently -k \"next dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron:build:win": "electron-builder --win --publish never && node scripts/copy-win-installer-alias.cjs",
    "electron:build:mac": "electron-builder --mac --publish never",
    "electron:build:all": "electron-builder --win --mac --publish never",
    "cap:sync": "npx cap sync android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:bundle": "npx cap sync android && cd android && ./gradlew bundleRelease",
    "android:apk": "npx cap sync android && cd android && ./gradlew assembleDebug"
  },
  "build": {
    "appId": "com.zeffai.desktop",
    "productName": "ZEFF AI",
    "copyright": "Copyright © ZEFF AI",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/logo-zeff.png",
        "to": "logo-zeff.png"
      },
      {
        "from": "build/license.txt",
        "to": "license.txt"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "artifactName": "zeffai.installer.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "ZEFF AI",
      "uninstallDisplayName": "ZEFF AI",
      "license": "build/license.txt",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "artifactName": "zeffai-mac.${ext}",
      "icon": "build/icon.png"
    },
    "dmg": {
      "title": "ZEFF AI Installer"
    }
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@google/genai": "^2.10.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.6.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "docx": "^9.7.1",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.42.2",
    "katex": "^0.16.47",
    "lucide-react": "^1.23.0",
    "mathjs": "^15.2.0",
    "next": "16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "plotly.js-dist-min": "^2.35.3",
    "pptxgenjs": "^4.0.1",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "resend": "^6.17.2",
    "stripe": "^22.3.1",
    "unpdf": "^1.6.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/plotly.js": "^2.35.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
