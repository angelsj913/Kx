generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth (Auth.js) 필수 모델 — 필드명은 @auth/prisma-adapter가 그대로 사용 ──

// 로그인은 구글 OAuth + 이메일/비밀번호(Credentials) 두 가지. 아이디·전화번호 필드는
// 두지 않는다 — 이메일이 이미 고유 식별자라 별도 "아이디"가 굳이 필요 없고, 필드가
// 늘어날수록(아이디 찾기 등) 공격 표면과 유지 비용만 늘어난다.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  /** 세션 토큰 버전 — 증가시키면 이전에 발급된 모든 JWT가 무효화된다("다른 기기 모두
     로그아웃" / 비밀번호 변경 시). JWT 전략에선 서버 세션 목록이 없어 이 방식으로 전역 폐기. */
  sessionVersion     Int       @default(0)
  /** 2단계 인증(이메일 OTP) 사용 여부 */
  twoFactorEnabled   Boolean   @default(false)

  /** 마지막 활동 시각 — 휴면 판정용 */
  lastActiveAt       DateTime?
  /** active | dormant */
  accountStatus      String    @default("active")
  dormantAt          DateTime?
  dormantNotifiedAt  DateTime?

  accounts     Account[]
  sessions     Session[]
  historyItems HistoryItem[]
  chatSessions ChatSession[]
  libraryItems LibraryItem[]
  inquiries    Inquiry[]
  orders       Order[]
  settings     UserSettings?

  ownedWorkspaces      Workspace[]           @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  sentInvites          WorkspaceInvite[]     @relation("InviteSender")
  reviewCards          ReviewCard[]
  paymentMethods       SavedPaymentMethod[]
  usageCounters        UsageCounter[]
  boardTasks           WorkBoardTask[]
  assignedBoardTasks   WorkBoardTask[]       @relation("WorkBoardAssignee")
  savedInsights        SavedInsight[]
  loginEvents          LoginEvent[]
}

/** 로그인 기록 — 보안 탭의 "최근 로그인" 표시 및 새 기기 알림용. */
model LoginEvent {
  id         String   @id @default(cuid())
  userId     String
  ip         String?
  userAgent  String?  @db.Text
  provider   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── 앱 전용 모델 ──

model HistoryItem {
  id         String   @id @default(cuid())
  userId     String
  toolId     String
  toolLabel  String
  outputType String
  prompt     String   @db.Text
  result     String   @db.Text
  fileUrl    String?
  fileName   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ChatSession {
  id            String   @id @default(cuid())
  userId        String
  workspaceId   String?
  title         String?
  libraryItemId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  libraryItem LibraryItem? @relation(fields: [libraryItemId], references: [id], onDelete: SetNull)
  history     ChatHistory[]

  @@index([userId, updatedAt])
  @@index([workspaceId, updatedAt])
}

model ChatHistory {
  id          String   @id @default(cuid())
  sessionId   String
  role        String
  text        String   @db.Text
  attachments Json?

  // 내부 전용(프론트에 노출 금지) — 어떤 에이전트/프로바이더/모델이 응답했는지, 시도 횟수
  agentId   String?
  provider  String?
  modelName String?
  attempts  Int?

  // 퀵툴 실행 결과(실제 파일 생성)일 때만 채워짐
  outputType     String  @default("chat")
  structuredKind String?
  resultData     String? @db.Text
  fileUrl        String?
  fileName       String?

  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model LibraryItem {
  id            String   @id @default(cuid())
  userId        String
  workspaceId   String?
  title         String
  fileUrl       String
  fileName      String
  mimeType      String
  extractedText String?  @db.Text
  createdAt     DateTime @default(now())

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  chatSessions ChatSession[]
  reviewCards  ReviewCard[]
  chunks       DocumentChunk[]

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
}

// ── 기업용 데이터 커넥터 / RAG (문서 청크 + 임베딩) ──
model DocumentChunk {
  id            String   @id @default(cuid())
  libraryItemId String
  userId        String
  workspaceId   String?
  idx           Int
  content       String   @db.Text
  embedding     Float[]
  provider      String   @default("local")
  createdAt     DateTime @default(now())

  libraryItem LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([libraryItemId])
}

// ── 자동 복습 스케줄러 (SM-2 간격 반복) ──
model ReviewCard {
  id            String    @id @default(cuid())
  userId        String
  workspaceId   String?
  libraryItemId String?
  front         String    @db.Text
  back          String    @db.Text

  // SM-2 스케줄링 상태
  ease           Float     @default(2.5)
  intervalDays   Int       @default(0)
  repetitions    Int       @default(0)
  dueAt          DateTime  @default(now())
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  libraryItem LibraryItem? @relation(fields: [libraryItemId], references: [id], onDelete: SetNull)

  @@index([userId, dueAt])
  @@index([workspaceId, dueAt])
}

// 이메일 6자리 OTP 임시 저장. 검증 성공 또는 만료 시 정리된다. 채널은 이메일만 —
// SMS 채널을 별도로 뒀다가 발송 검증 없이 코드를 그대로 노출한 사고가 있었어서
// (실제 발송 연동이 없는 채널을 아예 두지 않는 것 자체가 그 취약점 클래스를 원천 차단함),
// 앞으로도 이메일 외 채널은 추가하지 않는다.
model VerificationCode {
  id         String    @id @default(cuid())
  identifier String    // 대상 이메일 주소
  purpose    String    // "signup" | "find-password" | "workspace-delete" | "admin-plan-change"
  code       String    // 6자리
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([identifier, purpose])
}

model Inquiry {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  subject   String
  body      String   @db.Text
  email     String
  fileUrl   String?
  fileName  String?
  // 상태 머신: "등록" | "처리중" | "답변완료"
  status    String   @default("등록")
  reply     String?  @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

// ── 팀 워크스페이스 (협업: 여러 명이 같은 세션·서재 공유) ──

model Workspace {
  id         String   @id @default(cuid())
  name       String
  ownerId    String
  imageUrl   String?
  /** 짧은 초대 코드 — 상대가 붙여넣어 가입 */
  inviteCode String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner        User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]
  invites      WorkspaceInvite[]
  chatSessions ChatSession[]
  libraryItems LibraryItem[]
  reviewCards  ReviewCard[]
  boardTasks   WorkBoardTask[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  // "owner" | "admin" | "member"
  role        String   @default("member")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        String    @default("member")
  token       String    @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  plan              String   @default("free")
  language          String   @default("ko")
  enabledQuickTools String[] @default([])
  stripeCustomerId  String?
  /** 관리자가 사용자 AI 를 개별 차단할 때 true */
  aiDisabled        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/** 전역 키-값 설정 (AI 킬스위치, 한도 등) */
model SystemConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

/** 특정 사용자에 속하지 않는 전역 카운터(예: 전역 AI 일일 요청 상한). UsageCounter는
 * userId에 FK 제약이 있어 이런 용도로 쓸 수 없다. */
model GlobalCounter {
  id        String   @id @default(cuid())
  feature   String
  periodKey String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([feature, periodKey])
}

/** 인증 관련 라우트(로그인·회원가입·인증번호·초대코드) 고정 윈도우 rate limit */
model RateLimitHit {
  id         String   @id @default(cuid())
  scope      String
  identifier String
  windowKey  String
  count      Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([scope, identifier, windowKey])
  @@index([scope, windowKey])
}

// Stripe 결제 주문. merchantUid로 조회하고 웹훅으로 상태를 갱신한다.
model Order {
  id            String   @id @default(cuid())
  merchantUid   String   @unique
  userId        String?
  plan          String
  amount        Int      @default(0)
  currency      String   @default("krw")
  status        String   @default("pending") // "pending" | "paid" | "failed" | "canceled"
  stripeSession String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

/** 자체 결제수단 UI용(플랫폼 연동 전 로컬 저장). brand=visa|mastercard|amex|local 등 */
model SavedPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  brand     String
  last4     String
  holder    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/** 요금제 쿼터 집계 — periodKey: YYYY-MM 또는 YYYY-Www */
model UsageCounter {
  id        String   @id @default(cuid())
  userId    String
  feature   String
  periodKey String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature, periodKey])
  @@index([userId, feature])
}

/** 워크보드 칸반 태스크 (복습 스케줄러 대체) */
model WorkBoardTask {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String?
  assigneeId  String?
  title       String
  description String?   @db.Text
  status      String    @default("todo") // todo | doing | done
  priority    String    @default("normal") // low | normal | high
  dueAt       DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  assignee  User?      @relation("WorkBoardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([userId, status, updatedAt])
  @@index([workspaceId, status])
  @@index([assigneeId])
}

/**
 * 인사이트 보드(#16) — 워크보드를 대체한다. 지식 베이스 문서를 AI가 요약·핵심포인트로
 * 정리해 카드로 저장하고, 사용자는 이 카드들을 다시 열어보거나 고정/삭제하며 관리한다.
 * (문서 기반 요약 + 저장한 결과물 관리를 한 기능으로 합친 형태.)
 */
model SavedInsight {
  id            String   @id @default(cuid())
  userId        String
  workspaceId   String?
  /** 요약의 출처가 된 서재 항목(있으면). 항목이 지워지면 카드 자체는 남기고 연결만 끊는다. */
  libraryItemId String?
  /** 출처 문서 제목 스냅샷(libraryItem이 삭제돼도 표시용) */
  sourceName    String?
  title         String
  summary       String   @db.Text
  /** 핵심 포인트 — 문자열 배열의 JSON */
  keyPoints     String   @db.Text
  pinned        Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, pinned, createdAt])
  @@index([workspaceId])
}
