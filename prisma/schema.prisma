generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth (Auth.js) 필수 모델 — 필드명은 @auth/prisma-adapter가 그대로 사용 ──

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  phoneVerified DateTime?

  accounts     Account[]
  sessions     Session[]
  historyItems HistoryItem[]
  chatSessions ChatSession[]
  libraryItems LibraryItem[]
  inquiries    Inquiry[]
  orders       Order[]
  settings     UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── 앱 전용 모델 ──

model HistoryItem {
  id         String   @id @default(cuid())
  userId     String
  toolId     String
  toolLabel  String
  outputType String
  prompt     String   @db.Text
  result     String   @db.Text
  fileUrl    String?
  fileName   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ChatSession {
  id            String   @id @default(cuid())
  userId        String
  title         String?
  libraryItemId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  libraryItem LibraryItem? @relation(fields: [libraryItemId], references: [id], onDelete: SetNull)
  history     ChatHistory[]

  @@index([userId, updatedAt])
}

model ChatHistory {
  id          String   @id @default(cuid())
  sessionId   String
  role        String
  text        String   @db.Text
  attachments Json?

  // 내부 전용(프론트에 노출 금지) — 어떤 에이전트/프로바이더/모델이 응답했는지, 시도 횟수
  agentId   String?
  provider  String?
  modelName String?
  attempts  Int?

  // 퀵툴 실행 결과(실제 파일 생성)일 때만 채워짐
  outputType     String  @default("chat")
  structuredKind String?
  resultData     String? @db.Text
  fileUrl        String?
  fileName       String?

  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model LibraryItem {
  id            String   @id @default(cuid())
  userId        String
  title         String
  fileUrl       String
  fileName      String
  mimeType      String
  extractedText String?  @db.Text
  createdAt     DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatSessions ChatSession[]

  @@index([userId, createdAt])
}

// 이메일/전화 6자리 OTP 임시 저장. 검증 성공 또는 만료 시 정리된다.
model VerificationCode {
  id         String   @id @default(cuid())
  identifier String   // 이메일 주소 또는 전화번호
  channel    String   // "email" | "sms"
  purpose    String   @default("signup") // "signup" | "find-id" | "find-password"
  code       String   // 6자리
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([identifier, purpose])
}

model Inquiry {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  subject   String
  body      String   @db.Text
  email     String
  fileUrl   String?
  fileName  String?
  // 상태 머신: "등록" | "처리중" | "답변완료"
  status    String   @default("등록")
  reply     String?  @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  plan              String   @default("free")
  language          String   @default("ko")
  enabledQuickTools String[] @default([])
  stripeCustomerId  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Stripe 결제 주문. merchantUid로 조회하고 웹훅으로 상태를 갱신한다.
model Order {
  id            String   @id @default(cuid())
  merchantUid   String   @unique
  userId        String?
  plan          String
  amount        Int      @default(0)
  currency      String   @default("krw")
  status        String   @default("pending") // "pending" | "paid" | "failed" | "canceled"
  stripeSession String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}
