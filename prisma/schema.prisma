generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth (Auth.js) 필수 모델 — 필드명은 @auth/prisma-adapter가 그대로 사용 ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts     Account[]
  sessions     Session[]
  chatSessions ChatSession[]
  chatHistory  ChatHistory[]
  settings     UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── 앱 전용 모델 ──

// ── 채팅 세션(ChatGPT/Claude 스타일 "새 채팅" 단위) ──
model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  history ChatHistory[]

  @@index([userId, updatedAt])
}

// 세션 안의 한 턴(질문-답변 쌍). agent/model은 사용자에게 노출되지 않는
// 내부 전용 기록이다(백스테이지 멀티 에이전트가 실제로 어떤 에이전트를
// 썼는지 추적/디버깅하기 위한 용도).
model ChatHistory {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String
  message    String   @db.Text
  reply      String   @db.Text
  agent      String // 내부 전용: 어떤 에이전트가 최종 응답했는지 (예: "reasoning", "writing")
  provider   String // 내부 전용: "gemini" | "groq"
  model      String // 내부 전용: 실제 호출한 모델명
  attempts   Json? // 내부 전용: failover가 발생했다면 시도한 에이전트 순서 기록
  createdAt  DateTime @default(now())

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([userId, createdAt])
}

// 사용자별 설정: AI 모델 선호, 요금제 상태, 활성화된 퀵툴 카테고리 등.
model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  preferredProvider String   @default("gemini") // "gemini" | "groq"
  preferredModel    String?
  plan              String   @default("free") // "free" | "pro" | "professional"
  language          String   @default("ko") // "ko" | "en"
  enabledQuickTools Json? // 예: { "bizdoc": true, "ppt": false, ... }
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
