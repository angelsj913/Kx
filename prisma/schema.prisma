generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth (Auth.js) 필수 모델 — 필드명은 @auth/prisma-adapter가 그대로 사용 ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]
  historyItems  HistoryItem[]
  conversations ChatConversation[]
  chatHistory   ChatHistory[]
  settings      UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── 앱 전용 모델 ──

model HistoryItem {
  id         String   @id @default(cuid())
  userId     String
  toolId     String
  toolLabel  String
  outputType String
  prompt     String   @db.Text
  result     String   @db.Text
  fileUrl    String?
  fileName   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ChatConversation {
  id        String   @id @default(cuid())
  userId    String
  personaId String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String
  text           String   @db.Text
  attachments    Json?
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ── /api/chat 테스트 라우트(OpenRouter/Groq/Gemini 전환 테스트) 전용 모델 ──
// 기존 ChatConversation/ChatMessage(페르소나 채팅, 로그인 필수)와는 별개의
// 가벼운 1턴 질문-답변 로그다. userId를 nullable로 둬서, 아직 이 테스트
// 라우트에 로그인 연동을 하지 않은 상태에서도 바로 쓸 수 있게 했다.
model ChatHistory {
  id        String   @id @default(cuid())
  userId    String?
  provider  String // "gemini" | "groq" | "openrouter"
  model     String
  message   String   @db.Text
  reply     String   @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// 사용자별 AI 모델 선호 설정. 지금은 스키마만 준비해두고, 실제 화면(예:
// 설정 페이지에서 기본 프로바이더 선택)이 생기면 그때 API 라우트를 붙이면 된다.
model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  preferredProvider String   @default("gemini") // "gemini" | "groq" | "openrouter"
  preferredModel    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
