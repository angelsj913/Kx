generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── NextAuth (Auth.js) 필수 모델 — 필드명은 @auth/prisma-adapter가 그대로 사용 ──

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  phone         String?
  phoneVerified DateTime?

  accounts     Account[]
  sessions     Session[]
  historyItems HistoryItem[]
  chatSessions ChatSession[]
  libraryItems LibraryItem[]
  inquiries    Inquiry[]
  orders       Order[]
  settings     UserSettings?

  ownedWorkspaces      Workspace[]           @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  sentInvites          WorkspaceInvite[]     @relation("InviteSender")
  reviewCards          ReviewCard[]
  paymentMethods       SavedPaymentMethod[]
  usageCounters        UsageCounter[]
  boardTasks           WorkBoardTask[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── 앱 전용 모델 ──

model HistoryItem {
  id         String   @id @default(cuid())
  userId     String
  toolId     String
  toolLabel  String
  outputType String
  prompt     String   @db.Text
  result     String   @db.Text
  fileUrl    String?
  fileName   String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model ChatSession {
  id            String   @id @default(cuid())
  userId        String
  workspaceId   String?
  title         String?
  libraryItemId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  libraryItem LibraryItem? @relation(fields: [libraryItemId], references: [id], onDelete: SetNull)
  history     ChatHistory[]

  @@index([userId, updatedAt])
  @@index([workspaceId, updatedAt])
}

model ChatHistory {
  id          String   @id @default(cuid())
  sessionId   String
  role        String
  text        String   @db.Text
  attachments Json?

  // 내부 전용(프론트에 노출 금지) — 어떤 에이전트/프로바이더/모델이 응답했는지, 시도 횟수
  agentId   String?
  provider  String?
  modelName String?
  attempts  Int?

  // 퀵툴 실행 결과(실제 파일 생성)일 때만 채워짐
  outputType     String  @default("chat")
  structuredKind String?
  resultData     String? @db.Text
  fileUrl        String?
  fileName       String?

  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model LibraryItem {
  id            String   @id @default(cuid())
  userId        String
  workspaceId   String?
  title         String
  fileUrl       String
  fileName      String
  mimeType      String
  extractedText String?  @db.Text
  createdAt     DateTime @default(now())

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  chatSessions ChatSession[]
  reviewCards  ReviewCard[]
  chunks       DocumentChunk[]

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
}

// ── 기업용 데이터 커넥터 / RAG (문서 청크 + 임베딩) ──
model DocumentChunk {
  id            String   @id @default(cuid())
  libraryItemId String
  userId        String
  workspaceId   String?
  idx           Int
  content       String   @db.Text
  embedding     Float[]
  provider      String   @default("local")
  createdAt     DateTime @default(now())

  libraryItem LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([libraryItemId])
}

// ── 자동 복습 스케줄러 (SM-2 간격 반복) ──
model ReviewCard {
  id            String    @id @default(cuid())
  userId        String
  workspaceId   String?
  libraryItemId String?
  front         String    @db.Text
  back          String    @db.Text

  // SM-2 스케줄링 상태
  ease           Float     @default(2.5)
  intervalDays   Int       @default(0)
  repetitions    Int       @default(0)
  dueAt          DateTime  @default(now())
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  libraryItem LibraryItem? @relation(fields: [libraryItemId], references: [id], onDelete: SetNull)

  @@index([userId, dueAt])
  @@index([workspaceId, dueAt])
}

// 이메일/전화 6자리 OTP 임시 저장. 검증 성공 또는 만료 시 정리된다.
model VerificationCode {
  id         String   @id @default(cuid())
  identifier String   // 이메일 주소 또는 전화번호
  channel    String   // "email" | "sms"
  purpose    String   @default("signup") // "signup" | "find-id" | "find-password"
  code       String   // 6자리
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([identifier, purpose])
}

model Inquiry {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  subject   String
  body      String   @db.Text
  email     String
  fileUrl   String?
  fileName  String?
  // 상태 머신: "등록" | "처리중" | "답변완료"
  status    String   @default("등록")
  reply     String?  @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

// ── 팀 워크스페이스 (협업: 여러 명이 같은 세션·서재 공유) ──

model Workspace {
  id         String   @id @default(cuid())
  name       String
  ownerId    String
  imageUrl   String?
  /** 짧은 초대 코드 — 상대가 붙여넣어 가입 */
  inviteCode String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner        User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      WorkspaceMember[]
  invites      WorkspaceInvite[]
  chatSessions ChatSession[]
  libraryItems LibraryItem[]
  reviewCards  ReviewCard[]
  boardTasks   WorkBoardTask[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  // "owner" | "admin" | "member"
  role        String   @default("member")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  role        String    @default("member")
  token       String    @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
}

model UserSettings {
  id                String   @id @default(cuid())
  userId            String   @unique
  plan              String   @default("free")
  language          String   @default("ko")
  enabledQuickTools String[] @default([])
  stripeCustomerId  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Stripe 결제 주문. merchantUid로 조회하고 웹훅으로 상태를 갱신한다.
model Order {
  id            String   @id @default(cuid())
  merchantUid   String   @unique
  userId        String?
  plan          String
  amount        Int      @default(0)
  currency      String   @default("krw")
  status        String   @default("pending") // "pending" | "paid" | "failed" | "canceled"
  stripeSession String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

/** 자체 결제수단 UI용(플랫폼 연동 전 로컬 저장). brand=visa|mastercard|amex|local 등 */
model SavedPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  brand     String
  last4     String
  holder    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/** 요금제 쿼터 집계 — periodKey: YYYY-MM 또는 YYYY-Www */
model UsageCounter {
  id        String   @id @default(cuid())
  userId    String
  feature   String
  periodKey String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, feature, periodKey])
  @@index([userId, feature])
}

/** 워크보드 칸반 태스크 (복습 스케줄러 대체) */
model WorkBoardTask {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String?
  title       String
  description String?   @db.Text
  status      String    @default("todo") // todo | doing | done
  priority    String    @default("normal") // low | normal | high
  dueAt       DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, status, updatedAt])
  @@index([workspaceId, status])
}
