        { "layout": "table", "title": "비교", "table": { "headers": ["A", "B"], "rows": [["1", "2"], ["3", "4"], ["5", "6"]] }, "bullets": ["표 해석 첫 줄", "표 해석 둘째 줄"] },
        { "layout": "process", "title": "과정", "diagram": { "type": "process", "steps": [{ "label": "1", "desc": "첫 단계 설명" }, { "label": "2", "desc": "둘째 단계" }] }, "bullets": ["과정 요약 첫 번째 문장입니다", "과정 요약 두 번째 문장입니다"] },
        { "layout": "closing", "title": "끝", "bullets": ["감사"] }
      ]
    }
  },
  {
    "id": "ppt-validate-fail",
    "type": "ppt_validate",
