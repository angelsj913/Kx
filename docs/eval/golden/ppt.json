  { "id": "ppt-parse-3", "type": "ppt_parse", "input": { "title": "B", "slides": [{ "layout": "cycle", "title": "순환", "diagram": { "type": "cycle", "steps": [{ "label": "A", "desc": "d" }] }, "bullets": ["a", "b"] }, { "layout": "cards", "title": "카드", "diagram": { "type": "cards", "steps": [{ "label": "C", "desc": "d" }] }, "bullets": ["a", "b"] }, { "layout": "closing", "title": "끝" }] } },
  { "id": "ppt-parse-4", "type": "ppt_parse", "input": { "title": "C", "theme": { "preset": "tech" }, "slides": [{ "layout": "twoColumn", "title": "비교", "bullets": ["왼쪽"], "bulletsRight": ["오른쪽"], "subtitle": "s" }, { "layout": "content", "title": "x", "bullets": ["1", "2", "3"] }, { "layout": "closing", "title": "end" }] } },
  { "id": "ppt-parse-5", "type": "ppt_parse", "input": { "title": "D", "slides": [{ "layout": "content", "title": "t", "bullets": ["long bullet one here", "long bullet two here", "long bullet three"] }, { "layout": "content", "title": "t2", "bullets": ["a", "b", "c"] }, { "layout": "closing", "title": "end" }] } },
  { "id": "ppt-parse-6", "type": "ppt_parse", "input": { "title": "E", "slides": [{ "layout": "agenda", "title": "목차", "bullets": ["1", "2", "3", "4", "5"] }, { "layout": "section", "title": "S" }, { "layout": "content", "title": "C", "bullets": ["x", "y", "z"] }, { "layout": "closing", "title": "Q" }] } },
  { "id": "ppt-parse-7", "type": "ppt_parse", "input": { "title": "F", "slides": [{ "layout": "table", "title": "T", "table": { "headers": ["H1", "H2"], "rows": [["a", "b"], ["c", "d"], ["e", "f"]] }, "bullets": ["note"] }, { "layout": "content", "title": "c", "bullets": ["1", "2", "3"] }, { "layout": "closing", "title": "end" }] } },
